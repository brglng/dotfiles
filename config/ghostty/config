# font-family = Maple Mono NF CN
# font-family = Monaspace Argon LXGW Bright TC NF
font-family = Monaspace Xenon Noto Serif LXGW CJK TC NF
font-size = 16
font-feature = calt, ss01, ss02, ss03, ss04, ss05, ss06, ss07, ss08, ss09, ss10, liga
font-thicken = true
font-thicken-strength = 96
theme = light:Rose Pine Dawn,dark:Rose Pine
macos-titlebar-style = hidden
cursor-style = bar
cursor-style-blink = false
command = /bin/bash -c 'if [[ -x ~/.pixi/bin/nu ]]; then ~/.pixi/bin/nu -i -l; elif [[ -x /opt/homebrew/bin/nu ]]; then /opt/homebrew/bin/nu -i -l; elif [[ -x /opt/homebrew/bin/zsh ]]; then /opt/homebrew/bin/zsh -i -l; elif [[ -x /usr/local/bin/zsh ]]; then /usr/local/bin/zsh -i -l; else $SHELL; fi'
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
macos-option-as-alt = true
custom-shader = shaders/cursor_warp.glsl
custom-shader-animation = true
